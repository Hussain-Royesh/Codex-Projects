{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": false,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "noEmit": false,
    "outDir": ".test-dist",
    "rootDir": ".",
    "target": "ES2022",
    "tsBuildInfoFile": ".test-dist/tsconfig.test.tsbuildinfo",
    "types": ["node"]
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "tests/**/*.ts"],
  "exclude": ["node_modules", ".next", ".test-dist"]
}
